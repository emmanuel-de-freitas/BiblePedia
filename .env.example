# 🔐 Encrypted with dotenvx
# Copy this file to .env and fill in your values
# Then run: bunx dotenvx encrypt

# ==========================================
# Application Configuration
# ==========================================

# Node Environment (development | production | test)
NODE_ENV=development

# Application Port
PORT=5173

# Application URL
APP_URL=http://localhost:5173

# ==========================================
# Database Configuration
# ==========================================

# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/livrea
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=livrea_db

# ==========================================
# Authentication & Security
# ==========================================

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret
SESSION_SECRET=your-session-secret-key-change-this-in-production

# ==========================================
# External Services
# ==========================================

# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_COLLECTION_ID=your_collection_id

# API Keys
API_KEY=your-api-key
API_SECRET=your-api-secret

# ==========================================
# Tauri Configuration
# ==========================================

# Tauri Environment Variables
TAURI_ENV_DEBUG=false
TAURI_ENV_PLATFORM=

# ==========================================
# Feature Flags
# ==========================================

# Enable/Disable Features
ENABLE_ANALYTICS=false
ENABLE_DEBUG_MODE=false
ENABLE_BETA_FEATURES=false

# ==========================================
# Logging
# ==========================================

# Log Level (error | warn | info | debug | trace)
LOG_LEVEL=info

# Log Output (console | file | both)
LOG_OUTPUT=console

# ==========================================
# Performance & Optimization
# ==========================================

# Cache TTL in seconds
CACHE_TTL=3600

# Max Upload Size in MB
MAX_UPLOAD_SIZE=10

# ==========================================
# Development Tools
# ==========================================

# Hot Module Replacement
HMR_ENABLED=true

# Source Maps
GENERATE_SOURCEMAP=false

# ==========================================
# Third-party Services (Examples)
# ==========================================

# Stripe (if using payments)
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# AWS (if using AWS services)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Email Service (if sending emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@livrea.app

# ==========================================
# Notes
# ==========================================
# 1. Never commit real secrets to version control
# 2. Use dotenvx to encrypt sensitive values
# 3. Different environments should have different .env files
# 4. Variables prefixed with VITE_ are exposed to the browser
# 5. Keep production secrets in a secure secrets manager
