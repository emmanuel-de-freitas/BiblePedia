# .env.development
# Development Environment Variables
# 🔐 Encrypted with dotenvx

# ==========================================
# Application
# ==========================================
NODE_ENV=
PORT=
APP_URL=
# ==========================================
# Database
# ==========================================
DATABASE_URL=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ==========================================
# Authentication
# ==========================================
JWT_SECRET=
SESSION_SECRET=

# ==========================================
# Appwrite (Development)
# ==========================================
VITE_APPWRITE_ENDPOINT=
VITE_APPWRITE_PROJECT=
VITE_APPWRITE_DATABASE_ID=

# ==========================================
# API Keys (Development)
# ==========================================
API_KEY=
API_SECRET=

# ==========================================
# Feature Flags
# ==========================================
ENABLE_ANALYTICS=
ENABLE_DEBUG_MODE=
ENABLE_BETA_FEATURES=

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=
LOG_OUTPUT=

# ==========================================
# Development Tools
# ==========================================
HMR_ENABLED=
GENERATE_SOURCEMAP=
VITE_DEV_SERVER_HOST=

# ==========================================
# Performance
# ==========================================
CACHE_TTL=
MAX_UPLOAD_SIZE=

# ==========================================
# Development Services
# ==========================================
# Local development services can use simple credentials
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
