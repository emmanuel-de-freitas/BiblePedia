{
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@dotenvx/dotenvx": "^1.60.0",
    "@tauri-apps/cli": "^2.10.1",
    "turbo": "^2.9.4"
  },
  "name": "@biblepedia/monorepo",
  "packageManager": "bun@1.3.11",
  "private": true,
  "repository": "emmanuel-de-freitas/biblepedia",
  "scripts": {
    "build": "dotenvx run --env-file=.env.production -- turbo build",
    "clean": "rm -rf node_modules bun.lock .turbo && turbo clean",
    "dev": "dotenvx run --env-file=.env.development -- turbo dev",
    "desktop": "dotenvx run --env-file=.env.development -- turbo dev --filter @biblepedia/web --filter @biblepedia/desktop",
    "env:decrypt": "dotenvx decrypt",
    "env:encrypt": "dotenvx encrypt",
    "env:get": "dotenvx get",
    "env:ls": "dotenvx ls",
    "env:set": "dotenvx set",
    "lint": "turbo lint",
    "prebuild": "dotenvx ext prebuild",
    "precommit": "dotenvx precommit",
    "setup:env": "bun run scripts/setup-env.ts",
    "typecheck": "turbo typecheck"
  },
  "type": "module",
  "workspaces": {
    "catalog": {
      "@types/bun": "latest",
      "@heroui/react": "^3.0.1",
      "@heroui/styles": "^3.0.1",
      "@react-spectrum/s2": "^1.2.0",
      "@react-types/shared": "^3.33.1",
      "@tailwindcss/postcss": "^4.2.2",
      "@types/node": "25.5.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@uidotdev/usehooks": "^2.4.1",
      "iconsax-reactjs": "^0.0.8",
      "jotai": "^2.19.0",
      "motion": "^12.38.0",
      "postcss": "^8.5.8",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "react-router": "^7.14.0",
      "@react-router/dev": "^7.14.0",
      "@react-router/fs-routes": "^7.14.0",
      "@react-router/node": "^7.14.0",
      "tailwindcss": "^4.2.2",
      "autoprefixer": "^10.4.27",
      "concurrently": "^9.2.1",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "unplugin-parcel-macros": "^0.2.0",
      "zod": "^4.3.6"
    },
    "packages": [
      "packages/*",
      "apps/*"
    ]
  }
}
