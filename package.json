{
   "devDependencies": {
      "@dotenvx/dotenvx": "^1.59.1",
      "@tauri-apps/cli": "^2.10.1",
      "turbo": "^2.9.0"
   },
   "name": "@philagora/monorepo",
   "packageManager": "bun@1.3.11",
   "private": true,
   "repository": "MannyDefreitas7/@philagora",
   "scripts": {
      "build": "turbo build",
      "build:env": "dotenvx run --env-file=.env.production -- turbo build",
      "clean": "rm -rf node_modules bun.lock .turbo && turbo clean",
      "dev": "turbo dev",
      "dev:env": "dotenvx run --env-file=.env.development -- turbo dev",
      "env:decrypt": "dotenvx decrypt",
      "env:encrypt": "dotenvx encrypt",
      "env:get": "dotenvx get",
      "env:ls": "dotenvx ls",
      "env:set": "dotenvx set",
      "lint": "turbo lint",
      "prebuild": "dotenvx ext prebuild",
      "precommit": "dotenvx precommit",
      "setup:env": "bun run scripts/setup-env.ts",
      "typecheck": "turbo typecheck"
   },
   "type": "module",
   "workspaces": {
      "catalog": {
         "@react-types/shared": "^3.33.1",
         "@tailwindcss/postcss": "^4.2.2",
         "@types/node": "25.5.0",
         "@types/react": "^19.2.14",
         "@types/react-dom": "^19.2.3",
         "postcss": "^8.5.8",
         "react": "^19.2.4",
         "react-dom": "^19.2.4",
         "tailwindcss": "^4.2.2",
         "tsup": "^8.5.1",
         "typescript": "^6.0.2",
         "next": "^15.3.4",
         "@heroui/react": "^3.0.1",
         "@heroui/styles": "^3.0.1",
         "iconsax-reactjs": "^0.0.8",
         "motion": "^12.38.0",
         "zod": "^4.3.6",
         "jotai": "^2.19.0",
         "@uidotdev/usehooks": "^2.4.1",
         "unplugin-parcel-macros": "^0.2.0"
      },
      "packages": [
         "packages/*",
         "apps/*"
      ]
   }
}
