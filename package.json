{
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@tauri-apps/cli": "^2.10.1",
    "@dotenvx/dotenvx": "catalog:",
    "turbo": "^2.9.6"
  },
  "name": "@biblepedia/monorepo",
  "packageManager": "bun@1.3.11",
  "private": true,
  "repository": "emmanuel-de-freitas/biblepedia",
  "scripts": {
    "build": "turbo build",
    "postinstall": "turbo typegen && turbo setup",
    "setup": "turbo setup",
    "clean": "rm -rf node_modules bun.lock .turbo && turbo clean",
    "desktop": "turbo dev --filter @biblepedia/backend --filter @biblepedia/web --filter @biblepedia/desktop",
    "dev": "turbo dev --filter @biblepedia/web --filter @biblepedia/backend",
    "env:decrypt": "turbo env:decrypt",
    "env:encrypt": "turbo env:encrypt",
    "env:get": "dotenvx get",
    "env:ls": "dotenvx ls",
    "env:set": "dotenvx set",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "check": "turbo check",
    "check:fix": "biome check --write --unsafe .",
    "typecheck": "turbo typecheck"
  },
  "type": "module",
  "workspaces": {
    "catalog": {
      "@types/bun": "latest",
      "@heroui/react": "^3.0.1",
      "@heroui/styles": "^3.0.1",
      "@react-spectrum/s2": "^1.2.0",
      "@react-types/shared": "^3.33.1",
      "@tailwindcss/postcss": "^4.2.2",
      "@types/node": "25.5.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@uidotdev/usehooks": "^2.4.1",
      "electrobun": "1.16.0",
      "iconsax-reactjs": "^0.0.8",
      "jotai": "^2.19.0",
      "@dotenvx/dotenvx": "^1.60.1",
      "motion": "^12.38.0",
      "postcss": "^8.5.8",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "react-router": "^7.14.0",
      "@react-router/dev": "^7.14.0",
      "@react-router/fs-routes": "^7.14.0",
      "@react-router/node": "^7.14.0",
      "tailwindcss": "^4.2.2",
      "autoprefixer": "^10.4.27",
      "concurrently": "^9.2.1",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "unplugin-parcel-macros": "^0.2.0",
      "@vitejs/plugin-react": "^6.0.1",
      "vite": "^8.0.7",
      "zod": "^4.3.6"
    },
    "packages": [
      "packages/*",
      "apps/*"
    ]
  }
}
