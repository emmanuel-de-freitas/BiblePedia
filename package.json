{
  "name": "@philagora/monorepo",
  "private": true,
  "type": "module",
  "repository": "MannyDefreitas7/@philagora",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules bun.lock .turbo",
    "tauri": "cd apps/livrea && tauri",
    "tauri:dev": "cd apps/livrea && tauri dev",
    "tauri:build": "cd apps/livrea && tauri build",
    "env:encrypt": "dotenvx encrypt",
    "env:decrypt": "dotenvx decrypt",
    "env:set": "dotenvx set",
    "env:get": "dotenvx get",
    "env:ls": "dotenvx ls",
    "dev:env": "dotenvx run --env-file=.env.development -- turbo dev",
    "build:env": "dotenvx run --env-file=.env.production -- turbo build",
    "precommit": "dotenvx precommit",
    "prebuild": "dotenvx ext prebuild",
    "setup:env": "bun run scripts/setup-env.ts"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.2",
    "@tauri-apps/cli": "^2.9.6",
    "turbo": "^2.7.2"
  }
}
