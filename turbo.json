{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "setup": {
      "cache": true,
      "inputs": ["requirements.txt"],
      "outputs": [".venv/.turbo-installed"]
    },
    "build": {
      "dependsOn": [
        "^build",
        "setup"
      ],
      "outputs": [
        "build/**",
        ".react-router/**",
        "dist/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typegen": {
      "cache": true,
      "outputs": [
        ".react-router/**"
      ]
    },
    "format": {
      "cache": false
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check": {
      "dependsOn": [
        "typegen"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    }
  }
}
