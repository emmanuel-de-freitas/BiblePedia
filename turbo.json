{
   "$schema": "https://turbo.build/schema.json",
   "tasks": {
      "build": {
         "dependsOn": ["^build"],
         "outputs": ["build/**", ".react-router/**"]
      },
      "clean": {
         "cache": false
      },
      "dev": {
         "cache": false,
         "persistent": true
      },
      "lint": {
         "dependsOn": ["^lint"]
      },
      "tauri": {
         "cache": false
      },
      "tauri:build": {
         "dependsOn": ["build"],
         "outputs": ["src-tauri/target/**"]
      },
      "tauri:dev": {
         "cache": false,
         "dependsOn": ["build"],
         "persistent": true
      },
      "typecheck": {
         "dependsOn": ["^typecheck"]
      }
   },
   "ui": "tui"
}
