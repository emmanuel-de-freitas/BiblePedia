{
  "formatter": "language_server",
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.organizeImports": true,
    "source.fixAll": true
  },
  "tab_size": 2,
  "hard_tabs": true,
  "preferred_line_length": 100,
  "soft_wrap": "preferred_line_length",
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "lsp": {
    "biome": {
      "binary": {
        "path": "node_modules/@biomejs/biome/bin/biome",
        "arguments": ["lsp-proxy"]
      },
      "settings": {
        "enabled": true,
        "require_config_file": true
      }
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "importModuleSpecifier": "non-relative"
        }
      }
    }
  },
  "languages": {
    "TypeScript": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "tab_size": 2,
      "hard_tabs": true
    },
    "TSX": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "tab_size": 2,
      "hard_tabs": true
    },
    "JavaScript": {
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "tab_size": 2,
      "hard_tabs": true
    },
    "JSON": {
      "formatter": "language_server",
      "format_on_save": "on",
      "tab_size": 2,
      "hard_tabs": false
    },
    "JSONC": {
      "formatter": "language_server",
      "format_on_save": "on",
      "tab_size": 2,
      "hard_tabs": false
    },
    "Markdown": {
      "format_on_save": "off",
      "tab_size": 2,
      "hard_tabs": false,
      "soft_wrap": "preferred_line_length"
    }
  },
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
    "JSON": ["*.json", "tsconfig.json", "biome.json"],
    "JSONC": [".vscode/*.json"]
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "shell": {
      "program": "sh"
    },
    "working_directory": "current_project_directory",
    "env": {
      "TERM": "xterm-256color"
    }
  },
  "project_panel": {
    "dock": "left",
    "default_width": 240
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "notification_panel": {
    "dock": "right"
  },
  "vim_mode": false,
  "autosave": "on_focus_change",
  "scroll_beyond_last_line": "one_page",
  "vertical_scroll_margin": 3,
  "relative_line_numbers": false,
  "seed_search_query_from_cursor": "selection",
  "show_inline_completions": true,
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true
  },
  "assistant": {
    "enabled": true,
    "version": "2",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4"
    }
  }
}
