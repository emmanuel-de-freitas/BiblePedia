{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "vcs": {
    "defaultBranch": "master",
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
  },
  "formatter": {
    "enabled": true,
    "bracketSameLine": true,
    "bracketSpacing": true,
    "lineEnding": "lf",
    "indentStyle": "tab"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity":"error",
      "style": {
        "indentStyle":"space",
        "attributePosition":"multiline",
        "bracketSpacing": true,
        "enabled": true
      },
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "indentStyle":"space",
      "attributePosition":"multiline",
      "bracketSpacing": true,
      "enabled": true,
      "arrowParentheses": "asNeeded",
      "bracketSameLine": true,
      "semicolons": "asNeeded",
      "trailingCommas": "none",
      "quoteStyle": "double"
    }
  },
  "json": {
    "formatter": {
      "bracketSameLine": true,
      "trailingCommas": "none",
    },
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "recommended": true,
        "useSortedKeys": true,
        "organizeImports": true
      },
      "recommended": true,
      "useSortedKeys": true
    }
  }
}
