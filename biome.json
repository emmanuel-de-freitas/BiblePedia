{
  "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedKeys": "on"
      }
    },
    "enabled": true
  },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "bracketSameLine": true,
    "bracketSpacing": true,
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 3,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "nursery": {
        "useUniqueElementIds": "off"
      },
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    }
  },
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
