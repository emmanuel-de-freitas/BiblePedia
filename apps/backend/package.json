{
  "name": "@biblepedia/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "python3 -m venv .venv && .venv/bin/pip install --quiet -r requirements.txt && touch .venv/.turbo-installed",
    "build": "docker build -t biblepedia-backend .",
    "dev": ".venv/bin/fastapi dev app/main.py --port 8000",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --schema public",
    "db:new": "supabase migration new",
    "pgadmin": "docker compose up -d",
    "pgadmin:stop": "docker compose down",
    "clean": "rm -rf .venv **/__pycache__ .ruff_cache"
  }
}
