{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BiblePedia Documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#10B981",
    "dark": "#15803D",
    "background": {
      "light": "#FFFFFF",
      "dark": "#0F172A"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "installation", "project-structure"]
          },
          {
            "group": "Tech Stack",
            "pages": [
              "tech-stack/overview",
              "tech-stack/bun",
              "tech-stack/typescript",
              "tech-stack/biome",
              "tech-stack/turborepo"
            ]
          },
          {
            "group": "Desktop App",
            "pages": [
              "desktop/overview",
              "desktop/electrobun",
              "desktop/hot-reload",
              "desktop/windows",
              "desktop/development"
            ]
          },
          {
            "group": "Web App",
            "pages": [
              "web/overview",
              "web/react-router",
              "web/components",
              "web/styling",
              "web/state-management"
            ]
          },
          {
            "group": "UI Components",
            "pages": ["ui/react-spectrum", "ui/heroui", "ui/tailwindcss", "ui/motion"]
          },
          {
            "group": "Development",
            "pages": [
              "development/code-quality",
              "development/environment",
              "development/conventions",
              "development/workflows",
              "development/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Setup Guides",
            "pages": [
              "guides/biome-setup",
              "guides/environment-setup",
              "guides/desktop-setup",
              "guides/zed-editor"
            ]
          },
          {
            "group": "Development Guides",
            "pages": [
              "guides/creating-components",
              "guides/adding-routes",
              "guides/state-management",
              "guides/styling-guide"
            ]
          },
          {
            "group": "Deployment",
            "pages": ["guides/building", "guides/desktop-distribution"]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "reference/commands/development",
              "reference/commands/build",
              "reference/commands/code-quality"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "reference/config/biome",
              "reference/config/turborepo",
              "reference/config/electrobun",
              "reference/config/vite"
            ]
          },
          {
            "group": "Conventions",
            "pages": [
              "reference/conventions/naming",
              "reference/conventions/file-structure",
              "reference/conventions/imports"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/emmanuel-de-freitas/biblepedia",
          "icon": "github"
        },
        {
          "anchor": "Community",
          "href": "https://github.com/emmanuel-de-freitas/biblepedia/discussions",
          "icon": "comments"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Report Issue",
        "href": "https://github.com/emmanuel-de-freitas/biblepedia/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/emmanuel-de-freitas/biblepedia"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor", "vscode", "mcp"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/emmanuel-de-freitas/biblepedia"
    }
  },
  "topbar": {
    "style": "default"
  },
  "tabs": {
    "enabled": true
  },
  "analytics": {
    "plausible": {
      "domain": "docs.biblepedia.com"
    }
  },
  "seo": {
    "indexHiddenPages": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  }
}
