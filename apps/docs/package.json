{
  "name": "@biblepedia/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BiblePedia documentation site built with Mintlify",
  "scripts": {
    "dev": "mintlify dev",
    "validate": "mintlify validate",
    "broken-links": "mintlify broken-links",
    "export": "mintlify export",
    "a11y": "mintlify a11y",
    "clean": "rm -rf node_modules .turbo .mintlify",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "devDependencies": {
    "mintlify": "latest"
  }
}
