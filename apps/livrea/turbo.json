{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "clean": {
      "cache": false
    },
    "tauri:dev": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    },
    "tauri:build": {
      "outputs": [".next/**", "src-tauri/target/**"]
    }
  }
}
