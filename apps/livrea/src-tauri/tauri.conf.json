{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "livrea",
  "version": "0.1.0",
  "identifier": "com.philagora.livrea",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "center": true,
        "alwaysOnTop": true,
        "dragDropEnabled": false,
        "devtools": false,
        "allowLinkPreview": false,
        "focus": true,
        "height": 400,
        "create": false,
        "titleBarStyle": "Overlay",
        "decorations": false,
        "width": 700,
        "focusable": true,
        "resizable": false,
        "preventOverflow": true,
        "visible": false,
        "visibleOnAllWorkspaces": true,
        "zoomHotkeysEnabled": false,
        "backgroundThrottling": "disabled",
        "label": "splashscreen"
      },
      {
        "url": "dashboard",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "dragDropEnabled": true,
        "hiddenTitle": true,
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600,
        "maxWidth": 1920,
        "maxHeight": 1080,
        "fullscreen": false,
        "label": "dashboard"
      }
    ],
    "security": {
      "csp": "img-src 'self' data: https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
