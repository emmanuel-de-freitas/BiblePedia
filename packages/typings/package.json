{
   "description": "Shared TypeScript types, utility types, and environment variable declarations",
   "devDependencies": {
      "@types/node": "catalog:",
      "tsup": "catalog:",
      "typescript": "catalog:",
      "zod": "catalog:"
   },
   "exports": {
      ".": "./src/index.ts"
   },
   "files": [
      "dist",
      "src"
   ],
   "keywords": [
      "typescript",
      "types",
      "utilities",
      "environment-variables",
      "type-safety"
   ],
   "license": "MIT",
   "main": "./src/index.ts",
   "name": "@biblepedia/typings",
   "publishConfig": {
      "access": "public"
   },
   "repository": {
