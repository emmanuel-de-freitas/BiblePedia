{
  "name": "@biblepedia/utils",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf lib types node_modules .turbo",
    "typecheck": "tsc --noEmit",
    "build": "bun run biome check --write . && tsc",
    "check": "biome check --write . && tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@uidotdev/usehooks": "catalog:",
    "ua-parser-js": "^2.0.9"
  },
  "peerDependencies": {
    "react-router": "catalog:"
  }
}
